# Application
APP_NAME="Satryawiguna API"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=satryawiguna_db

# JWT — REQUIRED. Must be at least 32 characters. Never commit the real value.
# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Swagger Auth
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=admin123

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:8000"]



# DigitalOcean Spaces (S3-compatible storage)
# APP_ENV determines upload folder: "development"/"local" → "dev", "production" → "prod"
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET_NAME=satryawiguna-bucket
SPACES_REGION=sgp1
SPACES_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
SPACES_ORIGIN_ENDPOINT=https://satryawiguna-bucket.sgp1.digitaloceanspaces.com

# Brevo SMTP (email sending)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Brevo API (for advanced email features like templates, lists, etc.)
BREVO_API_KEY=